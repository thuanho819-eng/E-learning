@page
@model QuanLyLop2_ASP.NETCore.Pages.LamBaiModel

@if (TempData["msg"] != null)
{
    <p style="color:yellow">@TempData["msg"]</p>
}

<h2>@Model.bai?.TenBai</h2>

<div class="mb-3">
    <b>Nội dung đề:</b>
    <p>@Model.bai?.NoiDung</p>
</div>

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="MaBai" value="@Model.MaBai" />

    <div>
        <label class="form-text text-light" >Bài làm:</label><br />
        <textarea asp-for="NoiDungTraLoi" rows="6" cols="60"></textarea>
    </div>

    <br />

    <button type="submit" class="btn btn-success">Nộp bài</button>
</form>